{
  "name": "hormuz-risk-interface",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "fetch:fred": "node scripts/fetch-fred.mjs",
    "fetch:advisories": "node scripts/fetch-advisories.mjs",
    "fetch:traffic": "node scripts/fetch-traffic.mjs",
    "fetch:p0": "npm run fetch:fred && npm run fetch:advisories && npm run fetch:traffic",
    "build:evidence": "node scripts/build-local-evidence.mjs",
    "build:data": "npm run fetch:p0 && npm run build:evidence",
    "galaxy:hormuz": "node scripts/run-galaxy-hormuz.mjs",
    "galaxy:hormuz:run": "node scripts/run-galaxy-hormuz.mjs --execute",
    "forecast-agent:run": "node scripts/forecast-agent/runner.mjs",
    "audit:data": "node scripts/audit-data.mjs",
    "audit:galaxy": "node scripts/audit-galaxy.mjs",
    "audit:forecast-agent": "node scripts/audit-forecast-agent.mjs",
    "audit:evidence": "node scripts/audit-evidence.mjs",
    "audit:forecast": "node scripts/audit-forecast.mjs",
    "audit:legacy": "node scripts/audit-legacy.mjs",
    "audit:replay": "node scripts/audit-replay.mjs",
    "audit:ui": "node scripts/audit-ui.mjs",
    "audit": "npm run audit:data && npm run audit:galaxy && npm run audit:forecast-agent && npm run audit:evidence && npm run audit:forecast && npm run audit:replay && npm run audit:legacy && npm run audit:ui",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.19.0"
  }
}
